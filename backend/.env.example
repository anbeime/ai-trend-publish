# =============================================================================
# 数字人营销短视频生成平台 - 后端环境变量模板（无真实密钥）
# =============================================================================

# 应用配置
APP_NAME=TikTokGen
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# 数据库配置
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/tiktokgen

# Redis配置 (缓存/会话/队列)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_DB=0
REDIS_URL=redis://:change_me_redis_password@127.0.0.1:6379/0

# JWT配置
JWT_SECRET_KEY=change_me_jwt_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# GitHub OAuth配置
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/login/callback

# Index TTS配置
INDEX_TTS_API_KEY=
INDEX_TTS_BASE_URL=https://api.302.ai
INDEX_TTS_TIMEOUT=300

# SiliconFlow TTS配置
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_TTS_MODEL=IndexTeam/IndexTTS-2
SILICONFLOW_TTS_VOICE=
SILICONFLOW_TTS_TIMEOUT=120

# GLM 大模型配置
GLM_API_KEY=
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4.7
GLM_TIMEOUT=60

# Agnes AI 配置
AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_LLM_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0

# APIMart GPT-Image-2 配置
APIMART_API_KEY=
APIMART_BASE_URL=https://api.apimart.ai

# WaveSpeed AI数字人配置
WAVESPEED_API_KEY=
WAVESPEED_API_BASE_URL=https://api.302.ai/ws/api/v3
WAVESPEED_DEFAULT_RESOLUTION=480p
WAVESPEED_TIMEOUT=600

# 火山引擎 Ark Seedance 视频生成配置
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_SEEDANCE_MODEL=doubao-seedance-1-5-pro-251215
ARK_TIMEOUT=600
ARK_POLL_INTERVAL_SECONDS=3
ARK_SEEDANCE_DURATION=5
ARK_SEEDANCE_RESOLUTION=720p
ARK_SEEDANCE_ASPECT_RATIO=16:9
ARK_SEEDANCE_WATERMARK=true
ARK_SEEDANCE_CAMERA_FIXED=false
ARK_SEEDANCE_EXTRA_FLAGS=

# Banana Pro AI生图配置
BANANA_PRO_API_KEY=
BANANA_PRO_BASE_URL=https://api.banana.pro/v1
BANANA_PRO_MODEL=flux-pro

# 阿里云OSS配置
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_REGION=cn-beijing
OSS_PUBLIC_BASE_URL=

# ImgBB 图床配置
IMGBB_API_KEY=
IMGBB_BASE_URL=https://api.imgbb.com/1/upload
IMGBB_EXPIRATION=0

# 文件上传配置
MAX_UPLOAD_SIZE_MB=20
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp
ALLOWED_AUDIO_FORMATS=mp3,wav,m4a
ALLOWED_VIDEO_FORMATS=mp4,mov,avi

# Celery配置
CELERY_BROKER_URL=redis://:change_me_redis_password@127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://:change_me_redis_password@127.0.0.1:6379/2
CELERY_TASK_TIMEOUT=600
CELERY_TASK_SOFT_TIMEOUT=550

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS配置
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# 速率限制
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
