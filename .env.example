# =============================
# Docker Compose 示例配置
# =============================

# Project
COMPOSE_PROJECT_NAME=tiktok-video-lab
VITE_API_URL=http://localhost:3001/api/v1
FRONTEND_PORT=3000
BACKEND_PORT=3001
DOCKERHUB_NAMESPACE=kangarooking
IMAGE_TAG=v1.0.0

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tiktokgen

# Redis
REDIS_PASSWORD=change_me_redis_password

# App
APP_NAME=TikTokGen
APP_VERSION=1.0.0
APP_ENV=production
DEBUG=false
JWT_SECRET_KEY=change_me_jwt_secret_at_least_32_chars

# OAuth (optional but recommended)
GITHUB_CLIENT_ID=anbeime
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/auth/login/callback

# LLM / TTS / Video providers
INDEX_TTS_API_KEY=
INDEX_TTS_BASE_URL=https://api.302.ai
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_TTS_MODEL=IndexTeam/IndexTTS-2
GLM_API_KEY=
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4.7-flash
AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_LLM_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0
APIMART_API_KEY=
APIMART_BASE_URL=https://api.apimart.ai
WAVESPEED_API_KEY=
WAVESPEED_API_BASE_URL=https://api.302.ai/ws/api/v3
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_SEEDANCE_MODEL=doubao-seedance-1-5-pro-251215
BANANA_PRO_API_KEY=
BANANA_PRO_BASE_URL=https://api.banana.pro/v1
BANANA_PRO_MODEL=flux-pro

# OSS
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_REGION=cn-beijing
OSS_PUBLIC_BASE_URL=

# ImgBB
IMGBB_API_KEY=
IMGBB_BASE_URL=https://api.imgbb.com/1/upload
IMGBB_EXPIRATION=0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
